#!/usr/bin/env bash
# e2b-box — work with the E2B sandbox mirroring the current worktree.
#
#   e2b-box            open the sandbox shell for the current worktree (spinner
#                      while it boots; provisions one if none exists yet)
#   e2b-box open       same as above
#   e2b-box up         provision the sandbox in the background, don't attach
#   e2b-box shell      connect a shell now (fails if the sandbox isn't ready)
#   e2b-box status     print this worktree's sandbox record
#   e2b-box list       list every tracked sandbox
#   e2b-box url        print the preview URL
#   e2b-box logs       tail the provisioning log
#   e2b-box sync       re-upload the current worktree into its sandbox (local → sandbox)
#   e2b-box pull       download the sandbox's files back into this folder (sandbox → local;
#                      aborts on a dirty/non-git tree unless --force)
#   e2b-box kill       kill this worktree's sandbox
set -uo pipefail
# Resolve through the ~/.local/bin symlink to the real script dir so we can
# find lib/paths.sh (BSD readlink has no -f, so walk the links manually).
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  ldir="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [ "${SOURCE#/}" = "$SOURCE" ] && SOURCE="$ldir/$SOURCE"
done
DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
source "$DIR/lib/paths.sh"

need() { command -v "$1" >/dev/null 2>&1 || { echo "e2b-box: '$1' not found on PATH" >&2; exit 1; }; }
need jq

# When herdr opens this as a plugin pane/action, our cwd is the NEW pane's dir
# (often the plugin's own root) — NOT the folder you triggered from. herdr passes
# the real one in HERDR_PLUGIN_CONTEXT_JSON; cd there so all the $PWD-based logic
# (key, upload root, git) reflects the worktree you were actually in.
if [ -n "${HERDR_PLUGIN_CONTEXT_JSON:-}" ]; then
  ctx_cwd=$(printf '%s' "$HERDR_PLUGIN_CONTEXT_JSON" \
    | jq -r '.focused_pane_cwd // .focusedPaneCwd // .workspace_cwd // .workspaceCwd // empty' 2>/dev/null)
  [ -n "$ctx_cwd" ] && [ -d "$ctx_cwd" ] && cd "$ctx_cwd" || true
fi

# Current branch name — works on unborn branches (pre-first-commit) too.
git_branch() {
  git -C "$PWD" symbolic-ref --short HEAD 2>/dev/null \
    || git -C "$PWD" rev-parse --abbrev-ref HEAD 2>/dev/null \
    || true
}

# The folder we mirror into the sandbox: always the dir you're in. NOT the git
# toplevel — a loose folder inside a big mono-checkout would otherwise resolve
# to the whole enclosing repo and upload thousands of files.
box_root() { printf '%s' "$PWD"; }

# True when $PWD is itself a git repo/worktree root.
at_repo_root() {
  local top
  top=$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null || true)
  [ -n "$top" ] && [ "$top" = "$PWD" ]
}

# Sandbox identity = the folder (project) you're in — NOT the branch. A repo on
# "main" shouldn't key as "main" (useless + collides). Keyed by folder PATH
# (folder-name + a hash) so two same-named folders don't share a sandbox.
key_from_cwd() {
  box_key "$(box_root)"
}

# Human-facing name for the sandbox (prompt, notifications) — just the folder name,
# without the disambiguating hash in the key.
label_from_cwd() {
  e2b_key "$(basename "$(box_root)")"
}

rec()   { cat "$BOXES_DIR/$1.json" 2>/dev/null; }
field() { rec "$1" | jq -r --arg f "$2" '.[$f] // empty' 2>/dev/null; }

# Launch the provision worker in the background. op = ensure | sync.
# Marks the record "provisioning" but PRESERVES a known sandboxId so the worker
# can reconnect to (and resume) an existing sandbox instead of always creating fresh.
provision_from_cwd() {
  local k="$1" op="${2:-ensure}" b p l sid tpl payload node_bin
  b=""; at_repo_root && b=$(git_branch); [ "$b" = "HEAD" ] && b=""
  p=$(box_root)
  l=$(label_from_cwd)
  # This fn REPLACES the record wholesale (not a merge), so carry the identity
  # fields forward — otherwise a re-provision orphans the live sandbox (lost id)
  # or drops the resolved template (empties the dashboard/list column).
  sid=$(field "$k" sandboxId)
  tpl=$(field "$k" template)
  node_bin=$(e2b_node) || node_bin=""
  if [ -z "$node_bin" ]; then
    jq -cn --arg k "$k" --arg b "$b" --arg p "$p" --arg l "$l" --arg sid "$sid" --arg tpl "$tpl" \
      '{key:$k, label:$l, status:"failed", step:"needs Node >= 22 (set HERDR_E2B_NODE)", branch:$b, worktreePath:$p, workspaceId:""}
         + (if $sid != "" then {sandboxId:$sid} else {} end)
         + (if $tpl != "" then {template:$tpl} else {} end)' \
      > "$BOXES_DIR/$k.json"
    return 1
  fi
  jq -cn --arg k "$k" --arg b "$b" --arg p "$p" --arg l "$l" --arg sid "$sid" --arg tpl "$tpl" \
    '{key:$k, label:$l, status:"provisioning", step:"queued", branch:$b, worktreePath:$p, workspaceId:""}
       + (if $sid != "" then {sandboxId:$sid} else {} end)
       + (if $tpl != "" then {template:$tpl} else {} end)' \
    > "$BOXES_DIR/$k.json"
  payload=$(jq -cn --arg k "$k" --arg b "$b" --arg p "$p" --arg l "$l" --arg op "$op" \
    '{key:$k, label:$l, branch:$b, worktreePath:$p, workspaceId:"", op:$op}')
  nohup "$node_bin" "$PLUGIN_DIR/src/provision.js" "$payload" >>"$BOXES_DIR/$k.log" 2>&1 &
  disown 2>/dev/null || true
}

# Describe the clobber risk of pulling into $1 — a dirty git tree (uncommitted work)
# or a non-git folder (no `git diff`/undo) — or print nothing for a clean git tree.
# Shared by the `pull` case and the on-close prompt so both guard the same way.
pull_risk() {
  local d="$1"
  if git -C "$d" rev-parse --git-dir >/dev/null 2>&1; then
    [ -n "$(git -C "$d" status --porcelain 2>/dev/null)" ] && printf '%s' "$d has uncommitted changes"
  else
    printf '%s' "$d is not a git repo (overwrites can't be reviewed or undone via git)"
  fi
}

# After you exit the sandbox shell, decide what to do with the sandbox: pull your work
# back down, kill it, or leave it (auto_pause will pause it at the timeout).
on_close_prompt() {
  local k="$1" sid="$2" ans a2 risk dest node_bin lbl
  lbl=$(field "$k" label); : "${lbl:=$k}"
  [ -t 0 ] || return 0   # non-interactive: leave the sandbox as-is
  echo
  printf "left sandbox '%s' — [p]ull changes down · [k]ill it · [L]eave running: " "$lbl"
  read -r ans
  case "${ans:-L}" in
    p|P|pull)
      node_bin=$(e2b_node) || { echo "  needs Node >= 22 to pull"; return 0; }
      dest=$(box_root)
      # Same clobber guard as `e2b-box pull`: confirm before overwriting a dirty or
      # non-git tree. (This prompt is interactive — on_close only runs with a TTY.)
      risk=$(pull_risk "$dest")
      if [ -n "$risk" ]; then
        echo "  ⚠️  $risk — pull overwrites files from the sandbox."
        printf "  continue? [y/N] "; read -r a2
        case "$a2" in [Yy]*) ;; *) echo "  skipped pull — sandbox left running."; return 0 ;; esac
      fi
      echo "  pulling '$lbl' → $dest …"
      "$node_bin" "$PLUGIN_DIR/src/download.js" "$(jq -cn --arg k "$k" --arg d "$dest" '{key:$k,destRoot:$d}')"
      git -C "$dest" rev-parse --git-dir >/dev/null 2>&1 && echo "  review: git -C '$dest' diff"
      echo "  sandbox left running (auto-pauses at the timeout; e2b-box kill to stop it)."
      ;;
    k|K|kill)
      if sdk_kill "$sid" >/dev/null 2>&1; then
        echo "  killed sandbox '$lbl'."; rm -f "$BOXES_DIR/$k.json" "$BOXES_DIR/$k.log"
      else
        echo "  ! couldn't kill '$lbl' — keeping the record so it isn't orphaned; retry with 'e2b-box kill'."
      fi
      ;;
    *)
      echo "  left running — auto-pauses at the idle timeout; 'e2b-box open' to return."
      ;;
  esac
}

# Print the ready sandbox's details and open an interactive shell into it.
# In dashboard mode (E2B_DASH=1) stay quiet and skip the on-close prompt — the
# dashboard shows the sandbox details and handles pull/kill/leave itself.
connect_shell() {
  local k="$1" sid url ppath lbl
  sid=$(field "$k" sandboxId); url=$(field "$k" url); ppath=$(field "$k" projectPath)
  lbl=$(field "$k" label); : "${lbl:=$k}"
  [ -n "$sid" ] || return 1
  if [ "${E2B_DASH:-}" != 1 ]; then
    echo "● E2B sandbox ready for '$lbl'"
    [ -n "$url" ]   && echo "  preview : $url"
    [ -n "$ppath" ] && echo "  project : $ppath  (run: cd $ppath)"
    echo "  sandbox : $sid"
  fi
  ensure_e2b_path   # get a good node + the e2b CLI onto PATH (herdr may be on old node)
  ensure_e2b_key
  if ! command -v e2b >/dev/null 2>&1; then
    echo "  ! e2b CLI not found — 'npm i -g @e2b/cli'. Then: e2b sandbox connect $sid" >&2
    # The box is ready; only an interactive caller (that wanted to attach now) should
    # see this as a failure. Headless callers got the box + instructions → exit 0.
    { [ -t 0 ] && [ -t 1 ]; } && exit 1 || exit 0
  fi
  # The sandbox was just ensured live (reconnected/resumed) by provision.js, so
  # `e2b sandbox connect` can attach directly — no separate resume needed.
  # `e2b sandbox connect` needs a raw TTY; without one it crashes and would take
  # the pane with it. Guard so we show instructions instead of dying silently.
  if [ -t 0 ] && [ -t 1 ]; then
    [ "${E2B_DASH:-}" != 1 ] && { echo "  attaching a shell in the sandbox — type 'exit' when done, then you'll pick: [p]ull changes · [k]ill · [L]eave running"; echo; }
    local start=$SECONDS
    e2b sandbox connect "$sid"; local rc=$?   # blocks until you exit the shell
    # A fast non-zero exit means we never attached (box idle-timed-out / paused) —
    # not that your shell exited badly. Signal the caller so it can reprovision.
    if [ "$rc" -ne 0 ] && [ "$((SECONDS - start))" -lt 2 ]; then return 2; fi
    [ "${E2B_DASH:-}" = 1 ] && exit 0 # dashboard owns the post-exit pull/kill/leave
    on_close_prompt "$k" "$sid"
    return 0
  fi
  echo
  echo "  ! this pane has no interactive terminal, so I can't attach a live shell."
  echo "    run in any terminal:  e2b sandbox connect $sid"
  echo "    or open it:  ${url:-https://e2b.dev/dashboard/inspect/sandbox/$sid}"
  # Don't drop into a bare local shell (it isn't the sandbox and reads as if it
  # were). The box is up; the lines above say how to attach.
  exit 0
}

# Spin on the sandbox record until it's ready. $1=key, $2=verb ("booting"/"syncing").
# Renders the spinner only on a TTY, so headless callers (herdr actions, scripts)
# get clean output. Returns 0 when ready; prints the failure and returns 1 on a
# failed provision, a timeout, or a vanished record.
spin_until_ready() {
  local k="$1" verb="$2" raw st step laststep frames f i max missing lbl tty=0
  [ -t 1 ] && tty=1
  lbl=$(field "$k" label); : "${lbl:=$k}"
  frames=(⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏); i=0; max=4000   # ~20 min at 0.3s/iter (array = locale-safe indexing)
  missing=0; laststep="starting"
  while :; do
    raw=$(rec "$k")
    st=$(printf '%s' "$raw" | jq -r '.status // empty' 2>/dev/null)
    step=$(printf '%s' "$raw" | jq -r '.step // empty' 2>/dev/null)
    [ -n "$step" ] && laststep="$step"
    case "$st" in
      ready) break ;;
      failed) [ "$tty" = 1 ] && printf '\r\033[K'; echo "✗ E2B sandbox failed: ${step:-$laststep}"; echo "  see: e2b-box logs"; return 1 ;;
      "")  # transient (mid-write / just before first write) — tolerate briefly
        missing=$((missing + 1))
        if [ "$missing" -ge 20 ]; then
          [ "$tty" = 1 ] && printf '\r\033[K'; echo "sandbox record for '$k' went away — see: e2b-box logs"; return 1
        fi ;;
      *) missing=0 ;;
    esac
    if [ "$i" -ge "$max" ]; then
      [ "$tty" = 1 ] && printf '\r\033[K'; echo "timed out waiting for sandbox '$k' (last: $laststep). see: e2b-box logs"; return 1
    fi
    if [ "$tty" = 1 ]; then
      f=${frames[$((i % ${#frames[@]}))]}
      printf '\r\033[K%s  %s E2B sandbox for %s … %s' "$f" "$verb" "$lbl" "$laststep"
    fi
    i=$((i + 1))
    sleep 0.3
  done
  [ "$tty" = 1 ] && printf '\r\033[K'
  return 0
}

# Boot (ensure) the sandbox and attach a shell. provision.js is the single source of
# truth for liveness: it reconnects to (and resumes) the tracked sandbox, or creates
# a fresh one if it's gone — so there's no separate liveness poll here.
#   create_missing=1 (open) provisions when no record exists;
#   create_missing=0 (shell) errors instead, so `shell` only attaches to a sandbox
#                    you already have.
boot_and_connect() {
  local create_missing="$1" st
  st=$(field "$key" status)

  # Optimistic connect: if we already have a `ready` record with a sandbox id,
  # attach straight away — this skips the ensure Node cold-start for a box that's
  # already live (the common "reopen" case). On a fast failure (idle-timed-out /
  # paused) connect_shell returns non-zero and we fall through to provision +
  # resume below (which also auto-heals a dead box).
  #
  # ONLY with a TTY: the real `e2b sandbox connect` attempt IS the liveness check
  # here. With no TTY connect_shell can't attach and just prints instructions — so
  # a stale `ready` record would have it point at a dead box without reconciling.
  # Headless callers therefore skip this and go through `ensure` below (an SDK
  # reconnect/resume, or recreate if gone), so the box is verified live first.
  if [ "$st" = "ready" ] && [ -n "$(field "$key" sandboxId)" ] && [ -t 0 ] && [ -t 1 ]; then
    connect_shell "$key" && exit 0
    echo "  sandbox wasn't reachable — reprovisioning…"
  fi

  if [ "$st" != "provisioning" ]; then
    if [ -z "$st" ] && [ "$create_missing" != "1" ]; then
      echo "no sandbox tracked for '$key' — run 'e2b-box open' to boot one." >&2
      exit 1
    fi
    provision_from_cwd "$key" ensure
  fi
  # Spin until ready (bounded so a hung provision can't loop forever), then attach.
  spin_until_ready "$key" "booting" || exit 1
  connect_shell "$key" || { echo "✗ couldn't attach to '$key' — see: e2b-box logs" >&2; exit 1; }
}

cmd="${1:-open}"
[ $# -gt 0 ] && shift
key="${KEY:-$(key_from_cwd)}"
[ -z "$key" ] && key="workspace"

case "$cmd" in
  status)
    r=$(rec "$key")
    if [ -n "$r" ]; then
      printf '%s\n' "$r" | jq .
      [ "$(field "$key" status)" = ready ] && \
        echo "note: status is last known — a 'ready' box may be paused/idle-timed-out; 'e2b-box open' reconciles." >&2
    else
      echo "no sandbox tracked for '$key'"
    fi
    ;;
  list)
    shopt -s nullglob
    files=("$BOXES_DIR"/*.json)
    if [ ${#files[@]} -eq 0 ]; then echo "no sandboxes"; else
      printf '%-20s %-12s %-10s %-22s %s\n' BOX STATUS TEMPLATE SANDBOX URL
      for f in "${files[@]}"; do
        jq -r '[(.label // .key), (.status // "-"), (.template // "-"), (.sandboxId // "-"), (.url // "-")] | @tsv' "$f"
      done | while IFS=$'\t' read -r k s tpl sid u; do printf '%-20s %-12s %-10s %-22s %s\n' "$k" "$s" "$tpl" "$sid" "$u"; done
      echo "status is last known — a 'ready' box may be paused/idle-timed-out; 'e2b-box open' reconciles." >&2
    fi
    ;;
  url)
    u=$(field "$key" url)
    if [ -n "$u" ]; then echo "$u"; else echo "no sandbox tracked for '$key'" >&2; exit 1; fi
    ;;
  logs)  touch "$BOXES_DIR/$key.log"; tail -n +1 -f "$BOXES_DIR/$key.log" ;;
  sync)
    # Run in the FOREGROUND so the exit status is the worker's own (a backgrounded
    # worker + record-poll can't tell this sync's result from a concurrent one).
    # provision.js streams its steps to stderr on a TTY, so this isn't silent.
    node_bin=$(e2b_node) || { echo "needs Node >= 22 (set HERDR_E2B_NODE)"; exit 1; }
    b=""; at_repo_root && b=$(git_branch); [ "$b" = "HEAD" ] && b=""
    p=$(box_root)
    l=$(label_from_cwd)
    payload=$(jq -cn --arg k "$key" --arg b "$b" --arg p "$p" --arg l "$l" \
      '{key:$k, label:$l, branch:$b, worktreePath:$p, workspaceId:"", op:"sync"}')
    # sync provisions a fresh box when none is tracked yet — say so, so it isn't a
    # silent (billable) surprise for someone who expected an existing box to update.
    if [ -z "$(field "$key" sandboxId)" ]; then
      echo "no sandbox tracked for '$key' yet — provisioning a fresh one (creates a billable box)…"
    fi
    echo "re-uploading '$key' worktree into its sandbox…"
    "$node_bin" "$PLUGIN_DIR/src/provision.js" "$payload"
    ;;
  pull|download)
    force=0
    for a in "$@"; do case "$a" in --force|--yes|-y|-f) force=1 ;; esac; done
    node_bin=$(e2b_node) || { echo "needs Node >= 22 (set HERDR_E2B_NODE)"; exit 1; }
    st=$(field "$key" status)
    [ "$st" = "ready" ] || { echo "no ready sandbox for '$key' — nothing to pull"; exit 1; }
    dest=$(box_root)
    # Safety: pull overwrites local files with the sandbox's versions. On a dirty git
    # tree (uncommitted work at risk) or a non-git folder (no `git diff`/undo), require
    # explicit consent — prompt when interactive, else ABORT unless --force is given.
    # Never silently clobber a non-interactive caller (e.g. a herdr action, a script).
    risk=$(pull_risk "$dest")
    if [ -n "$risk" ] && [ "$force" -ne 1 ]; then
      echo "⚠️  $risk — pull overwrites files from the sandbox."
      if [ -t 0 ]; then
        printf "continue? [y/N] "; read -r ans; case "$ans" in [Yy]*) ;; *) echo "aborted"; exit 0 ;; esac
      else
        echo "aborted (non-interactive) — re-run with --force to overwrite." >&2; exit 1
      fi
    fi
    payload=$(jq -cn --arg k "$key" --arg d "$dest" '{key:$k, destRoot:$d}')
    echo "pulling sandbox '$key' → $dest …"
    # Propagate a download failure (set -e isn't on) instead of masking it with the
    # trailing git/echo below.
    "$node_bin" "$PLUGIN_DIR/src/download.js" "$payload" || exit $?
    # `if` (not `&&`) so a non-git $dest doesn't leave the failing rev-parse status
    # (128) as this case arm's — and the script's — exit code on a successful pull.
    if git -C "$dest" rev-parse --git-dir >/dev/null 2>&1; then echo "review:  git -C '$dest' diff"; fi
    ;;
  kill)
    sid=$(field "$key" sandboxId)
    if [ -z "$sid" ]; then
      rm -f "$BOXES_DIR/$key.json" "$BOXES_DIR/$key.log"; echo "cleared '$key' (no sandbox tracked)"
    elif sdk_kill "$sid"; then
      rm -f "$BOXES_DIR/$key.json" "$BOXES_DIR/$key.log"; echo "killed sandbox for '$key'"
    else
      # kill failed — KEEP the record (with the sandbox id) so the box isn't
      # silently orphaned & billable. Retry, or check `e2b sandbox list`.
      echo "✗ couldn't kill $sid for '$key' — record kept so you can retry: e2b-box kill" >&2
      exit 1
    fi
    ;;
  up)
    # Boot the sandbox in the background; don't attach.
    st=$(field "$key" status)
    case "$st" in
      ready) echo "sandbox for '$key' already ready — 'e2b-box open' to attach" ;;
      provisioning) echo "sandbox for '$key' already provisioning ($(field "$key" step)) — e2b-box logs" ;;
      *)
        echo "provisioning E2B sandbox for '$key' in the background…"
        provision_from_cwd "$key" ensure
        echo "watch: e2b-box logs   ·   attach when ready: e2b-box open"
        ;;
    esac
    ;;
  shell)
    # Attach to a sandbox you already have (resume/heal it if needed); don't create
    # one from scratch.
    boot_and_connect 0
    ;;
  open)
    # Ensure the sandbox is live (reconnect/resume, or create if missing) then attach.
    boot_and_connect 1
    ;;
  *)
    echo "usage: e2b-box [open|up|shell|status|list|url|logs|sync|pull [--force]|kill]" >&2
    exit 2
    ;;
esac
