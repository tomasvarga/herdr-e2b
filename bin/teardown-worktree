#!/usr/bin/env bash
# herdr event hook: worktree.removed
# Kill the sandbox tied to this worktree so no billable box is left orphaned.
set -uo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$DIR/lib/paths.sh"

command -v jq >/dev/null 2>&1 || exit 0

ev="${HERDR_PLUGIN_EVENT_JSON:-}"
[ -z "$ev" ] && exit 0

wt_path=$(printf '%s' "$ev" | jq -r '[.. | .path? // empty | strings][0] // empty' 2>/dev/null)
[ -z "$wt_path" ] && exit 0
# Box key = the worktree's folder name — same convention as e2b-box (which keys
# off the folder you're in), so we find the record the box was created under.
key=$(e2b_key "$(basename "$wt_path")")
[ -z "$key" ] && exit 0

[ -f "$BOXES_DIR/$key.json" ] || exit 0   # no box for this worktree — nothing to do
sid=$(jq -r '.sandboxId // empty' "$BOXES_DIR/$key.json" 2>/dev/null)
if [ -n "$sid" ]; then
  sdk_kill "$sid" >/dev/null 2>&1 || true   # SDK kill (bounded); no e2b CLI needed
  herdr notification show "E2B" --body "Box for $key torn down" >/dev/null 2>&1 || true
fi
rm -f "$BOXES_DIR/$key.json" "$BOXES_DIR/$key.log" 2>/dev/null || true
exit 0
